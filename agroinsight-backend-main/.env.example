# Porta do servidor HTTP
PORT=3000

# Segredo usado para assinar os tokens JWT (TROCAR EM PRODUÇÃO)
JWT_SECRET=trocar_em_producao

# Tempo de expiração do access token (ex.: 15m, 1h, 7d)
JWT_EXPIRES_IN=1h

# Base URLs da API climática Open-Meteo (gratuita, sem API key)
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

# LLM (Google Gemini) — chave gratuita em https://aistudio.google.com/app/apikey
# Sem a chave, o sistema usa recomendações por regras (fallback) automaticamente.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
